# Application
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# AWS
AWS_REGION=us-east-1

# DynamoDB (local via Docker)
DYNAMODB_TABLE_NAME=eventmesh-local
DYNAMODB_ENDPOINT=http://localhost:8000

# Cognito (populate after CDK deployment)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_JWKS_URL=

# SQS (populate after CDK deployment)
SQS_ORDER_QUEUE_URL=
SQS_PAYMENT_QUEUE_URL=

# SNS (populate after CDK deployment)
SNS_ORDER_TOPIC_ARN=

# SES
SES_FROM_EMAIL=noreply@eventmesh.dev

# Stripe (get from dashboard.stripe.com/test)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# WebSocket (populate after CDK deployment)
WEBSOCKET_API_ENDPOINT=